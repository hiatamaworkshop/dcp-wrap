{
  "hooks": {
    "enabled": true,
    "processes": {
      "dcp_encoder": {
        "enabled": true,
        "priority": 50,
        "transport": "stdio",
        "command": ["node", "./node_modules/dcp-wrap/dist/picoclaw-hook.js"],
        "intercept": ["after_tool"],
        "env": {
          "PICOCLAW_DCP_TOOLS": "{\"mcp_engram_pull\":{\"id\":\"engram-recall:v1\",\"fields\":[\"id\",\"relevance\",\"summary\",\"tags\",\"hitCount\",\"weight\",\"status\"]},\"mcp_engram_ls\":{\"id\":\"engram-scan:v1\",\"fields\":[\"id\",\"summary\",\"tags\",\"hitCount\",\"weight\",\"status\"]},\"web_search\":\"auto\"}"
        }
      }
    }
  }
}